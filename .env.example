# Neon PostgreSQL (https://neon.tech)
DATABASE_URL="postgresql://neondb_owner:[password]@e...."

# Cloudinary image storage (https://cloudinary.com → Dashboard)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
