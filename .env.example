CLOUDINARY_API_SECRET="your-api-secret"

# Admin secret path — visit /YOUR_SECRET to access admin panel
ADMIN_SECRET="some-secret-path"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
